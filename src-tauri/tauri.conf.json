{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ISAMS",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ISAMS - Integrated Smart Academic Management System",
        "width": 1000,
        "height": 800,
        "visible": false,
        "dragDropEnabled": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      },
      {
        "label": "splashscreen",
        "title": "ISAMS Loading...",
        "url": "splashscreen.html",
        "width": 450,
        "height": 350,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}